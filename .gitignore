# Local DuckDB (override path with JD_STAGING_DATA_DIR)
data/*.duckdb
data/*.db

# Optional EPUB library for batch ingest (override with JD_BOOKS_DIR)
books/*
!books/.gitkeep

# Generated next to the DB when embedding
**/jds_books_duckdb_manifest.json

# Local Chroma / embedding data — do not commit
archive/chromadb/chroma_persist/*

# Chroma data folder — do not commit
data/chroma_db/*
